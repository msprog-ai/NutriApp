rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NutriFridge AI Security Rules
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a strict Path-Based Ownership model for all user-specific data. 
     * Authorization is derived directly from the document path, ensuring that users can 
     * only access data nested under their own authenticated UID.
     *
     * DATA STRUCTURE:
     * - /user_profiles/{userId}: User metadata and preferences.
     * - /users/{userId}/{collection}/{id}: User-owned subcollections (Inventory, Saved Recipes, etc.)
     * - /recipes/{recipeId}: A top-level, public-read collection for curated or AI-generated recipes.
     *
     * KEY SECURITY DECISIONS:
     * 1. Path-based Authorization: By using the {userId} wildcard in the path, we achieve 
     *    "Authorization Independence," meaning we don't need expensive get() calls to 
     *    verify ownership.
     * 2. Prototyping Flexibility: While ownership and relational integrity (matching 
     *    internal IDs to the path) are strictly enforced, the specific shape and types 
     *    of content fields remain flexible to allow for rapid UI/Schema iteration.
     * 3. System-Locked Recipes: The global /recipes collection is readable by any 
     *    authenticated user but cannot be modified by clients.
     * 4. Relational Integrity: On document creation, we enforce that any internal 
     *    'userId' or 'id' field matches the path parameter to ensure data consistency.
     */

    // --- HELPER FUNCTIONS ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is the owner and the document currently exists. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the UserProfile entity, which stores core user preferences.
     * @path /user_profiles/{userId}
     * @allow (get) If the user's UID matches the profile ID.
     * @deny (list) Global listing of user profiles is strictly prohibited for privacy.
     * @principle Path-based ownership and relational integrity for the root profile.
     */
    match /user_profiles/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users cannot list other users or even their own profile path; they must 'get' by ID.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for system-defined and AI-generated recipes.
     * @path /recipes/{recipeId}
     * @allow (get, list) Any authenticated user can read recipes.
     * @deny (create, update, delete) Clients cannot modify the global recipe catalog.
     * @principle Public consumption with system-locked writes.
     */
    match /recipes/{recipeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false; // System-only or Admin-only writes (not defined in IR for client-side).
    }

    /**
     * @description Shared rule logic for user-owned subcollections.
     * @path /users/{userId}/...
     * @principle All data under the /users/{userId} path is strictly owned by that specific user.
     */
    match /users/{userId} {
      
      /**
       * @description Inventory items (ingredients, fridge contents).
       * @path /users/{userId}/inventory_items/{itemId}
       * @allow (create) If userId matches path and internal data.
       * @deny (update) If trying to change the userId of an existing item.
       */
      match /inventory_items/{itemId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Saved recipes link for a user.
       * @path /users/{userId}/saved_recipes/{savedId}
       */
      match /saved_recipes/{savedId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description User interaction history with recipes.
       * @path /users/{userId}/recipe_history_entries/{historyId}
       */
      match /recipe_history_entries/{historyId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Shopping list items.
       * @path /users/{userId}/shopping_list_items/{itemId}
       */
      match /shopping_list_items/{itemId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description User-specific meal planning.
       * @path /users/{userId}/meal_plan_entries/{mealId}
       */
      match /meal_plan_entries/{mealId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Notifications directed to the user.
       * @path /users/{userId}/notifications/{notificationId}
       */
      match /notifications/{notificationId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}